# Committed source of truth for operator-tunable values. Copy to `.env` (gitignored)
# to override locally; `docker compose` and `make` (-include .env) auto-load `.env`.
# Shell scripts source `.env.example` first, then `.env`. Values here are the defaults.
#
# NOTE: app/sidecar ports (consumer :6000, daprd :3500/:50001) are NOT here — they are
# YAML-coupled constants (Program.AppBindUrl, k8s Service :80->6000, dapr run --app-port),
# not free tunables, per rules/common/configuration.md "Excluded categories".

# === Kafka broker image (Renovate-tracked; single source of truth for the 3-node compose) ===
# renovate: datasource=docker depName=apache/kafka
KAFKA_IMAGE=apache/kafka:4.2.0@sha256:9516fb7634bad307d17c33b589fde9023003b0cb761374f500002b980a3149b9

# === 3-node KRaft cluster (docker-compose.yaml — advanced path via `make local-kafka-run`) ===
KAFKA_HOST_1=172.28.1.1
KAFKA_HOST_2=172.28.1.2
KAFKA_HOST_3=172.28.1.3
KAFKA_CLUSTER_ID=4L6g3nShT-eMCtK--X86sw

# === Single-broker compose (docker-compose-kafka.yaml — default demo path) ===
KAFKA_HOST_PORT=9092

# === e2e harness timing knobs (e2e/*.sh) ===
MSG_WAIT_SECONDS=60
POLL_INTERVAL_SECONDS=3
CURL_MAX_TIME_SECONDS=5
CONSUMER_START_WAIT_SECONDS=10
