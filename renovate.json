{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":semanticCommitType(chore)"
  ],
  "commitMessagePrefix": "chore(all): ",
  "commitMessageAction": "update",
  "commitBody": "Signed-off-by: Renovate Bot <bot@renovateapp.com>",
  "labels": [
    "dependencies"
  ],
  "prConcurrentLimit": 50,
  "prHourlyLimit": 0,
  "platformAutomerge": true,
  "automerge": true,
  "automergeType": "pr",
  "automergeStrategy": "squash",
  "ignoreTests": false,
  "enabledManagers": [
    "docker-compose",
    "dockerfile",
    "github-actions",
    "kubernetes",
    "nuget",
    "mise",
    "custom.regex"
  ],
  "kubernetes": {
    "managerFilePatterns": ["/^k8s/.+\\.yaml$/"]
  },
  "vulnerabilityAlerts": {
    "labels": [
      "security"
    ],
    "automerge": true,
    "minimumReleaseAge": "0 days"
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update Makefile plain version constants via inline renovate comments (no colons in value)",
      "managerFilePatterns": ["/^Makefile$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)( versioning=(?<versioning>\\S+))?( registryUrl=(?<registryUrl>\\S+))?\\n[A-Z_]+\\s*:=\\s*(?<currentValue>[^:\\s]+)\\s*$"
      ]
    },
    {
      "customType": "regex",
      "description": "Update Makefile Docker image ref constants with optional digest (repo:tag@sha256:...)",
      "managerFilePatterns": ["/^Makefile$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)( versioning=(?<versioning>\\S+))?\\n[A-Z_]+\\s*:=\\s*\\S+?:(?<currentValue>[^@\\s]+)(@(?<currentDigest>sha256:[a-f0-9]+))?"
      ]
    },
    {
      "customType": "regex",
      "description": "Update .mise.toml tool pins via inline renovate comments",
      "managerFilePatterns": ["/^\\.mise\\.toml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)( versioning=(?<versioning>\\S+))?\\n[\"a-zA-Z0-9_/:-]+\\s*=\\s*\"(?<currentValue>[^\"]+)\""
      ]
    },
    {
      "customType": "regex",
      "description": "Update .env Docker image pins with optional digest (KEY=<repo>:<tag>@sha256:...)",
      "managerFilePatterns": ["/^\\.env$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)( versioning=(?<versioning>\\S+))?\\n[A-Z_]+=\\S+?:(?<currentValue>[^@\\s]+)(@(?<currentDigest>sha256:[a-f0-9]+))?"
      ]
    }
  ],
  "packageRules": [
    {
      "description": "Wait 3 days before automerging major updates",
      "matchUpdateTypes": [
        "major"
      ],
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Group GitHub Actions into one PR",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "GitHub Actions"
    },
    {
      "description": "Group .NET Docker images (minor/patch only)",
      "groupName": "Dotnet Docker images",
      "matchPackageNames": [
        "dotnet-sdk",
        "mcr.microsoft.com/dotnet/aspnet",
        "mcr.microsoft.com/dotnet/sdk",
        "mcr.microsoft.com/dotnet/runtime",
        "mcr.microsoft.com/dotnet/runtime-deps"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch",
        "digest",
        "pin",
        "pinDigest"
      ],
      "pinDigests": false
    },
    {
      "description": "Group Dapr SDK dependencies",
      "groupName": "Dapr SDK",
      "matchPackageNames": ["Dapr.*"]
    },
    {
      "description": "Group Makefile and .mise.toml tool versions into a single PR",
      "matchManagers": [
        "custom.regex"
      ],
      "groupName": "tool versions"
    },
    {
      "description": "Self-owned app images are released by the project; do not update via Renovate",
      "matchPackageNames": [
        "andriykalashnykov/producer",
        "andriykalashnykov/consumer"
      ],
      "enabled": false
    }
  ]
}
