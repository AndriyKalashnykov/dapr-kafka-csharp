{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":semanticCommitType(chore)"
  ],
  "commitMessagePrefix": "chore(all): ",
  "commitMessageAction": "update",
  "commitBody": "Signed-off-by: Renovate Bot <bot@renovateapp.com>",
  "labels": [
    "dependencies"
  ],
  "prConcurrentLimit": 50,
  "prHourlyLimit": 0,
  "platformAutomerge": true,
  "automerge": true,
  "automergeType": "branch",
  "automergeStrategy": "squash",
  "ignoreTests": false,
  "enabledManagers": [
    "docker-compose",
    "dockerfile",
    "github-actions",
    "nuget",
    "custom.regex"
  ],
  "vulnerabilityAlerts": {
    "labels": [
      "security"
    ],
    "automerge": true,
    "minimumReleaseAge": "0 days"
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track act version in Makefile",
      "managerFilePatterns": ["/^Makefile$/"],
      "matchStrings": [
        "ACT_VERSION\\s*:=\\s*(?<currentValue>.*?)\\n"
      ],
      "depNameTemplate": "nektos/act",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "Track nvm version in Makefile",
      "managerFilePatterns": ["/^Makefile$/"],
      "matchStrings": [
        "NVM_VERSION\\s*:=\\s*(?<currentValue>.*?)\\n"
      ],
      "depNameTemplate": "nvm-sh/nvm",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "Track hadolint version in Makefile",
      "managerFilePatterns": ["/^Makefile$/"],
      "matchStrings": [
        "HADOLINT_VERSION\\s*:=\\s*(?<currentValue>.*?)\\n"
      ],
      "depNameTemplate": "hadolint/hadolint",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "Track Dapr version in Makefile",
      "managerFilePatterns": ["/^Makefile$/"],
      "matchStrings": [
        "DAPR_VERSION\\s*:=\\s*(?<currentValue>.*?)\\n"
      ],
      "depNameTemplate": "dapr/dapr",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.*)$"
    }
  ],
  "packageRules": [
    {
      "description": "Wait 3 days before automerging major updates",
      "matchUpdateTypes": [
        "major"
      ],
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Group GitHub Actions into one PR",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "GitHub Actions"
    },
    {
      "description": "Group .NET Docker images, minor and patch only",
      "groupName": "Dotnet Docker images",
      "matchPackageNames": [
        "dotnet-sdk",
        "mcr.microsoft.com/dotnet/aspnet",
        "mcr.microsoft.com/dotnet/sdk",
        "mcr.microsoft.com/dotnet/runtime",
        "mcr.microsoft.com/dotnet/runtime-deps"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch",
        "digest",
        "pin",
        "pinDigest"
      ],
      "pinDigests": false
    },
    {
      "description": "Group XUnit test dependencies",
      "groupName": "XUnit",
      "matchPackageNames": [
        "/^xunit/"
      ]
    },
    {
      "description": "Group Dapr SDK dependencies",
      "groupName": "Dapr SDK",
      "matchPackageNames": [
        "/^Dapr/"
      ]
    },
    {
      "description": "Group Makefile tool versions",
      "matchManagers": [
        "custom.regex"
      ],
      "groupName": "Makefile tools"
    }
  ]
}
